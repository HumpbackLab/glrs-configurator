{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Gyro ELRS Configurator",
  "version": "0.1.0",
  "identifier": "org.expresslrs.gyro-configurator",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5200",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Gyro ELRS Configurator",
        "width": 1180,
        "height": 820,
        "minWidth": 360,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://* https://*; img-src 'self' data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "ELRS gyro and flight-control configurator",
    "longDescription": "Configurator for ELRS basic flight-control receivers using HTTP configuration and future MSP-over-WiFi debug polling."
  }
}
